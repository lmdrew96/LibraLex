# LibraLex environment variables.
# Copy to .env.local and fill in. Never commit .env.local.
# Production domain: libra.adhdesigns.dev

# ── Convex (backend / realtime DB) ────────────────────────────────────────────
# NEXT_PUBLIC_CONVEX_URL + CONVEX_DEPLOYMENT are written for you by `npx convex dev`.
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=

# ── Clerk (auth) ──────────────────────────────────────────────────────────────
# Reuse the unified ADHDesigns Clerk instance (same one FeyForge uses) — do NOT
# create a new Clerk app. For local dev you can reuse FeyForge's dev keys.
# From clerk.com > your app > API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk JWT issuer domain — must match the instance the keys above belong to.
# This is ALSO set as a Convex env var (npx convex env set CLERK_JWT_ISSUER_DOMAIN ...)
# so convex/auth.config.ts can validate tokens. Dev instance default is baked in
# as a fallback (see convex/auth.config.ts).
CLERK_JWT_ISSUER_DOMAIN=

# ── Google Books (STRONGLY RECOMMENDED in production) ────────────────────────
# Two jobs: (1) backfills covers Open Library lacks, and (2) is the SEARCH FALLBACK
# when Open Library's slow/flaky text+author search times out or returns empty.
# Keyless requests share a global daily quota and 429 almost immediately, so without
# a key the search fallback can't fire and a slow OL spell surfaces as a 504. Set
# this in the deployment env (Vercel), not just .env.local — .env.local isn't deployed.
# From console.cloud.google.com > APIs > Books API.
GOOGLE_BOOKS_API_KEY=

# ── ThriftBooks affiliate (OPTIONAL) ──────────────────────────────────────────
# The "Find on ThriftBooks" links work with no config — this just lets them carry
# an affiliate tag when you have one. Set it to the raw query-string fragment to
# append to every ThriftBooks link, e.g. NEXT_PUBLIC_THRIFTBOOKS_AFFILIATE=oly_enc_id=XXXX
# Leave blank for plain links. ThriftBooks' affiliate program is free to join.
NEXT_PUBLIC_THRIFTBOOKS_AFFILIATE=

# Routing — Clerk's <SignIn>/<SignUp> are mounted at these paths.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/
